<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>In-Browser AI Chat</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: #0b0f1a;
      color: #e5e7eb;
      height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    #app {
      width: 100%;
      max-width: 860px;
      height: 100vh;
      display: flex;
      flex-direction: column;
      background: #111827;
      box-shadow: 0 0 40px rgba(0,0,0,0.6);
    }

    header {
      padding: 14px 22px;
      background: #0f172a;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border-bottom: 1px solid #1f2937;
      flex-wrap: wrap;
    }

    header h1 {
      font-size: 1.15rem;
      font-weight: 700;
      background: linear-gradient(135deg, #818cf8 0%, #c084fc 60%, #f472b6 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .meta {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.8rem;
      color: #94a3b8;
    }

    #model-select {
      background: #0b1220;
      color: #e5e7eb;
      border: 1px solid #1f2937;
      border-radius: 8px;
      padding: 6px 10px;
      font-size: 0.8rem;
      cursor: pointer;
      outline: none;
      max-width: 220px;
    }

    #model-select:focus { border-color: #818cf8; }

    #reset-btn {
      background: transparent;
      border: 1px solid #818cf8;
      color: #c7d2fe;
      padding: 6px 14px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.8rem;
      transition: all 0.2s;
    }

    #reset-btn:hover { background: #818cf8; color: #0b0f1a; }
    #reset-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    #progress-bar {
      width: 100%;
      height: 3px;
      background: #1f2937;
      overflow: hidden;
      display: none;
    }

    #progress-bar.active { display: block; }

    #progress-fill {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, #818cf8, #c084fc, #f472b6);
      transition: width 0.3s ease;
    }

    #chat-window {
      flex: 1;
      overflow-y: auto;
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      scroll-behavior: smooth;
    }

    #chat-window::-webkit-scrollbar { width: 6px; }
    #chat-window::-webkit-scrollbar-track { background: transparent; }
    #chat-window::-webkit-scrollbar-thumb { background: #1f2937; border-radius: 3px; }

    .message {
      display: flex;
      gap: 12px;
      max-width: 88%;
      animation: fadeIn 0.25s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .message.user { align-self: flex-end; flex-direction: row-reverse; }
    .message.assistant { align-self: flex-start; }
    .message.system { align-self: center; max-width: 95%; }

    .avatar {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
    }

    .message.user .avatar { background: linear-gradient(135deg, #f472b6, #c084fc); }
    .message.assistant .avatar { background: linear-gradient(135deg, #818cf8, #6366f1); }

    .bubble {
      padding: 11px 15px;
      border-radius: 16px;
      line-height: 1.55;
      font-size: 0.95rem;
      white-space: pre-wrap;
      word-break: break-word;
    }

    .message.user .bubble {
      background: linear-gradient(135deg, #6d28d9, #be185d);
      color: white;
      border-bottom-right-radius: 4px;
    }

    .message.assistant .bubble {
      background: #1e293b;
      color: #e5e7eb;
      border: 1px solid #334155;
      border-bottom-left-radius: 4px;
    }

    .bubble.error {
      background: #450a0a;
      border-color: #7f1d1d;
      color: #fecaca;
    }

    .bubble.info {
      background: #1e1b4b;
      border-color: #3730a3;
      color: #c7d2fe;
      font-size: 0.85rem;
    }

    .typing-indicator span {
      display: inline-block;
      width: 7px; height: 7px;
      background: #94a3b8;
      border-radius: 50%;
      margin: 0 2px;
      animation: bounce 1.2s infinite;
    }

    .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

    @keyframes bounce {
      0%, 80%, 100% { transform: translateY(0); }
      40% { transform: translateY(-7px); }
    }

    #input-area {
      padding: 14px 22px;
      background: #0f172a;
      display: flex;
      gap: 10px;
      align-items: flex-end;
      border-top: 1px solid #1f2937;
    }

    #user-input {
      flex: 1;
      background: #0b1220;
      border: 1px solid #1f2937;
      border-radius: 12px;
      padding: 12px 16px;
      color: #e5e7eb;
      font-size: 0.95rem;
      resize: none;
      max-height: 150px;
      outline: none;
      transition: border-color 0.2s;
      font-family: inherit;
    }

    #user-input:focus { border-color: #818cf8; }
    #user-input::placeholder { color: #475569; }
    #user-input:disabled { opacity: 0.5; }

    #send-btn {
      background: linear-gradient(135deg, #818cf8, #c084fc);
      border: none;
      border-radius: 12px;
      width: 48px;
      height: 48px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: filter 0.2s, transform 0.1s;
      flex-shrink: 0;
    }

    #send-btn:hover { filter: brightness(1.1); }
    #send-btn:active { transform: scale(0.95); }
    #send-btn:disabled { background: #334155; cursor: not-allowed; filter: none; }
    #send-btn svg { width: 20px; height: 20px; fill: white; }

    .welcome {
      text-align: center;
      color: #64748b;
      margin: auto;
      padding: 0 24px;
    }

    .welcome h2 {
      font-size: 1.5rem;
      margin-bottom: 10px;
      background: linear-gradient(135deg, #818cf8, #f472b6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .welcome p { font-size: 0.92rem; line-height: 1.6; }
    .welcome .hint { margin-top: 10px; font-size: 0.8rem; color: #475569; }
  </style>
</head>
<body>
<div id="app">
  <header>
    <h1>In-Browser AI</h1>
    <div class="meta">
      <select id="model-select" title="Choose model">
        <option value="Llama-3.2-1B-Instruct-q4f16_1-MLC">Llama 3.2 1B (fastest)</option>
        <option value="Qwen2.5-1.5B-Instruct-q4f16_1-MLC">Qwen 2.5 1.5B (fast)</option>
        <option value="gemma-2-2b-it-q4f16_1-MLC">Gemma 2 2B</option>
        <option value="Phi-3.5-mini-instruct-q4f16_1-MLC">Phi 3.5 Mini</option>
        <option value="Llama-3.2-3B-Instruct-q4f16_1-MLC">Llama 3.2 3B (smarter, slower)</option>
        <option value="Hermes-3-Llama-3.2-3B-q4f16_1-MLC">Hermes 3 (3B, slower)</option>
      </select>
      <span id="status-label">initializing…</span>
    </div>
    <button id="reset-btn" disabled>New Chat</button>
  </header>

  <div id="progress-bar"><div id="progress-fill"></div></div>

  <div id="chat-window">
    <div class="welcome" id="welcome-msg">
      <h2>Modern AI, running in your browser</h2>
      <p>This page loads an open-source LLM directly into your browser using WebGPU — no server, no API key, your messages never leave your device.</p>
      <p class="hint">The first message will trigger a one-time model download (a few hundred MB). It's cached after that.</p>
      <p class="hint">Live headlines from WSJ, FT, BBC, and CNN + a Wikipedia lookup are pulled in for every question — so it can answer about specific people, events, and elections, not just recent news.</p>
    </div>
  </div>

  <div id="input-area">
    <textarea
      id="user-input"
      rows="1"
      placeholder="Loading model… one moment"
      disabled
    ></textarea>
    <button id="send-btn" disabled title="Send">
      <svg viewBox="0 0 24 24"><path d="M2 21l21-9L2 3v7l15 2-15 2z"/></svg>
    </button>
  </div>
</div>

<script type="module">
  import * as webllm from "https://esm.run/@mlc-ai/web-llm@0.2.79";

  const chatWindow = document.getElementById('chat-window');
  const input = document.getElementById('user-input');
  const sendBtn = document.getElementById('send-btn');
  const resetBtn = document.getElementById('reset-btn');
  const modelSelect = document.getElementById('model-select');
  const statusLabel = document.getElementById('status-label');
  const progressBar = document.getElementById('progress-bar');
  const progressFill = document.getElementById('progress-fill');

  let engine = null;
  let isGenerating = false;

  function buildSystemPrompt() {
    const now = new Date();
    const iso = now.toISOString().slice(0, 16).replace('T', ' ');
    const dateStr = now.toLocaleDateString('en-US', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
    });
    const timeStr = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
    const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
    const year = now.getFullYear();
    const lang = navigator.language || 'en-US';

    return [
      `IMPORTANT — TODAY'S DATE IS ${dateStr}. THE YEAR IS ${year}. THE CURRENT LOCAL TIME IS ${timeStr} (${tz}). ISO: ${iso}.`,
      `If the user asks the date, time, year, or day of the week, answer using ONLY the values above. Do not say it is any other year. Your training data is older than this date.`,
      '',
      'You are an in-browser AI assistant running entirely inside the user\'s web browser using WebLLM and WebGPU. There is no cloud server; messages never leave the device.',
      '',
      `You are hosted on artgeorge.github.io, a personal site with browser games and this chat page. The user's browser language is ${lang}.`,
      '',
      'YOUR INTERNAL KNOWLEDGE IS OUTDATED. Your training data cutoff is in 2023 or 2024. Today is far later. The Wikipedia article(s) and news headlines provided BELOW are current and authoritative. If your memory conflicts with the provided Wikipedia/news content, the provided content is correct and your memory is wrong — defer to the provided sources.',
      '',
      'ABSOLUTE RULE — DO NOT REFUSE. Never reply with "I cannot provide information," "I don\'t have access to that," "I can\'t help with that," or any variant. Elections, people, events, sports, business, science, and history are ALL fair game. Always give your best answer combining (a) the provided Wikipedia extract, (b) the provided news headlines, and (c) your training knowledge — in that order of priority. If something is uncertain, say what you DO know and qualify it ("per the Wikipedia article above," "according to recent WSJ headlines") — but never refuse outright.',
      '',
      'When you cite a fact, briefly name the source: "Wikipedia," "WSJ," "FT," "BBC," or "CNN." Include the article URL where given.',
      '',
      'Style: friendly, accurate, and direct. Match the user\'s language. Use Markdown when helpful.',
      '',
      `Reminder: today is ${dateStr}, year ${year}.`
    ].join('\n');
  }

  let history = [
    { role: 'system', content: buildSystemPrompt() }
  ];

  function escapeHtml(text) {
    return text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function clearWelcome() {
    const w = document.getElementById('welcome-msg');
    if (w) w.remove();
  }

  function appendMessage(role, content, opts = {}) {
    clearWelcome();
    const div = document.createElement('div');
    div.className = `message ${role}`;
    const avatar = role === 'user' ? '🧑' : (role === 'system' ? 'ℹ️' : '✨');
    const bubbleClass = opts.error ? 'error' : (role === 'system' ? 'info' : '');
    div.innerHTML = `
      <div class="avatar">${avatar}</div>
      <div class="bubble ${bubbleClass}">${escapeHtml(content)}</div>
    `;
    chatWindow.appendChild(div);
    chatWindow.scrollTop = chatWindow.scrollHeight;
    return div.querySelector('.bubble');
  }

  function showTyping() {
    clearWelcome();
    const div = document.createElement('div');
    div.className = 'message assistant';
    div.id = 'typing';
    div.innerHTML = `
      <div class="avatar">✨</div>
      <div class="bubble typing-indicator">
        <span></span><span></span><span></span>
      </div>
    `;
    chatWindow.appendChild(div);
    chatWindow.scrollTop = chatWindow.scrollHeight;
  }

  function removeTyping() {
    const t = document.getElementById('typing');
    if (t) t.remove();
  }

  // === Live news (WSJ + FT + BBC + CNN RSS via CORS proxy) ===
  const NEWS_FEEDS = [
    // Wall Street Journal
    { name: 'World', publisher: 'WSJ', url: 'https://feeds.a.dj.com/rss/RSSWorldNews.xml' },
    { name: 'US Business', publisher: 'WSJ', url: 'https://feeds.a.dj.com/rss/WSJcomUSBusiness.xml' },
    { name: 'Markets', publisher: 'WSJ', url: 'https://feeds.a.dj.com/rss/RSSMarketsMain.xml' },
    { name: 'Tech', publisher: 'WSJ', url: 'https://feeds.a.dj.com/rss/RSSWSJD.xml' },
    { name: 'Opinion', publisher: 'WSJ', url: 'https://feeds.a.dj.com/rss/RSSOpinion.xml' },
    // Financial Times
    { name: 'Home', publisher: 'FT', url: 'https://www.ft.com/?format=rss' },
    { name: 'World', publisher: 'FT', url: 'https://www.ft.com/world?format=rss' },
    { name: 'Companies', publisher: 'FT', url: 'https://www.ft.com/companies?format=rss' },
    { name: 'Markets', publisher: 'FT', url: 'https://www.ft.com/markets?format=rss' },
    // BBC
    { name: 'Top', publisher: 'BBC', url: 'https://feeds.bbci.co.uk/news/rss.xml' },
    { name: 'World', publisher: 'BBC', url: 'https://feeds.bbci.co.uk/news/world/rss.xml' },
    { name: 'Business', publisher: 'BBC', url: 'https://feeds.bbci.co.uk/news/business/rss.xml' },
    { name: 'Politics', publisher: 'BBC', url: 'https://feeds.bbci.co.uk/news/politics/rss.xml' },
    { name: 'Tech', publisher: 'BBC', url: 'https://feeds.bbci.co.uk/news/technology/rss.xml' },
    // CNN
    { name: 'Top', publisher: 'CNN', url: 'http://rss.cnn.com/rss/cnn_topstories.rss' },
    { name: 'World', publisher: 'CNN', url: 'http://rss.cnn.com/rss/edition_world.rss' },
    { name: 'US', publisher: 'CNN', url: 'http://rss.cnn.com/rss/edition_us.rss' },
    { name: 'Tech', publisher: 'CNN', url: 'http://rss.cnn.com/rss/edition_technology.rss' },
    { name: 'Business', publisher: 'CNN', url: 'http://rss.cnn.com/rss/money_news_international.rss' }
  ];
  const NEWS_CACHE_KEY = 'news-headlines-v2';
  const NEWS_CACHE_TTL_MS = 10 * 60 * 1000;
  const CORS_PROXIES = [
    u => `https://corsproxy.io/?${encodeURIComponent(u)}`,
    u => `https://api.allorigins.win/raw?url=${encodeURIComponent(u)}`,
    u => `https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(u)}`
  ];
  let wsjHeadlines = [];

  let modelStatusText = 'initializing…';
  let newsState = 'idle';

  function setStatus(text) {
    modelStatusText = text;
    renderStatus();
  }

  function setNewsState(state) {
    newsState = state;
    renderStatus();
  }

  function renderStatus() {
    const parts = [modelStatusText];
    if (newsState === 'loading') parts.push('loading news…');
    else if (newsState === 'ok') parts.push(`news ✓ (${wsjHeadlines.length})`);
    else if (newsState === 'error') parts.push('news ✕');
    statusLabel.textContent = parts.join(' · ');
  }

  async function fetchViaProxy(url) {
    let lastErr;
    for (const wrap of CORS_PROXIES) {
      try {
        const res = await fetch(wrap(url));
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const text = await res.text();
        if (text.length < 200) throw new Error('response too short');
        return text;
      } catch (err) {
        lastErr = err;
      }
    }
    throw lastErr;
  }

  function parseRSS(xml, feed) {
    try {
      const doc = new DOMParser().parseFromString(xml, 'text/xml');
      if (doc.querySelector('parsererror')) return [];
      return Array.from(doc.querySelectorAll('item')).map(item => ({
        title: (item.querySelector('title')?.textContent || '').trim(),
        summary: (item.querySelector('description')?.textContent || '').replace(/<[^>]+>/g, '').trim(),
        pubDate: item.querySelector('pubDate')?.textContent || '',
        link: item.querySelector('link')?.textContent || '',
        category: feed.name,
        publisher: feed.publisher
      })).filter(i => i.title);
    } catch (err) {
      return [];
    }
  }

  function loadCachedNews() {
    try {
      const raw = localStorage.getItem(NEWS_CACHE_KEY);
      if (!raw) return null;
      const { ts, headlines } = JSON.parse(raw);
      if (!headlines || !headlines.length) return null;
      if (Date.now() - ts > NEWS_CACHE_TTL_MS) return null;
      return headlines;
    } catch { return null; }
  }

  function saveCachedNews(headlines) {
    try {
      localStorage.setItem(NEWS_CACHE_KEY, JSON.stringify({ ts: Date.now(), headlines }));
    } catch {}
  }

  async function loadNews(force = false) {
    if (!force) {
      const cached = loadCachedNews();
      if (cached) {
        wsjHeadlines = cached;
        setNewsState('ok');
        return;
      }
    }
    setNewsState('loading');
    try {
      const results = await Promise.allSettled(
        NEWS_FEEDS.map(async f => parseRSS(await fetchViaProxy(f.url), f))
      );
      const all = results.flatMap(r => r.status === 'fulfilled' ? r.value : []);
      if (!all.length) throw new Error('all feeds failed');
      wsjHeadlines = all.sort((a, b) =>
        new Date(b.pubDate || 0) - new Date(a.pubDate || 0)
      );
      saveCachedNews(wsjHeadlines);
      setNewsState('ok');
    } catch (err) {
      console.warn('news fetch failed', err);
      setNewsState('error');
    }
  }

  const STOPWORDS = new Set(['the','and','for','what','where','when','how','about','tell','give','from','this','that','with','are','will','would','could','should','have','has','was','were','any','more','than','some','news','latest','article','say','said','today','yesterday','please','can','you','your','their','they','his','her','its','our','out','was','off','also','just','only','very','here','there']);

  function findRelevantHeadlines(query, limit = 10) {
    if (!wsjHeadlines.length) return [];
    const words = (query.toLowerCase().match(/[a-z][a-z0-9]{2,}/g) || []).filter(w => !STOPWORDS.has(w));
    if (!words.length) return wsjHeadlines.slice(0, 8);
    const scored = wsjHeadlines.map(h => {
      const title = h.title.toLowerCase();
      const text = title + ' ' + h.summary.toLowerCase();
      let score = 0;
      for (const w of words) {
        if (title.includes(w)) score += 2;
        else if (text.includes(w)) score += 1;
      }
      return { h, score };
    });
    const matches = scored.filter(s => s.score > 0).sort((a, b) => b.score - a.score).map(s => s.h);
    if (matches.length >= limit) return matches.slice(0, limit);
    const seen = new Set(matches.map(m => m.link));
    for (const recent of wsjHeadlines) {
      if (matches.length >= limit) break;
      if (!seen.has(recent.link)) matches.push(recent);
    }
    return matches.slice(0, limit);
  }

  const PUBLISHER_LONG = { WSJ: 'Wall Street Journal', FT: 'Financial Times', BBC: 'BBC', CNN: 'CNN' };

  // === Wikipedia lookup (free, CORS-enabled, no auth) ===
  function extractWikiQuery(message) {
    return message
      .replace(/^(who|what|when|where|why|how|did|does|do|was|were|is|are|can|could|will|would|should|please|tell\s+me\s+about|tell\s+me|give\s+me|find|look\s+up|search\s+for|i\s+want\s+to\s+know|do\s+you\s+know)\s+/gi, '')
      .replace(/[?.!,;:]+$/g, '')
      .trim()
      .slice(0, 200);
  }

  function generateWikiQueries(message) {
    const queries = [];
    const cleaned = extractWikiQuery(message);
    if (cleaned) queries.push(cleaned);
    const yearMatch = cleaned.match(/\b(19|20)\d{2}\b/);
    if (yearMatch) {
      const year = yearMatch[0];
      const withoutYear = cleaned.replace(new RegExp(`\\b${year}\\b`, 'g'), '').replace(/\s+/g, ' ').trim();
      if (withoutYear) {
        queries.push(`${year} ${withoutYear}`);
        queries.push(withoutYear);
      }
    }
    const seen = new Set();
    return queries.filter(q => q && q.length >= 3 && !seen.has(q.toLowerCase()) && seen.add(q.toLowerCase()));
  }

  async function fetchWikipediaArticle(query) {
    if (!query || query.length < 3) return null;
    try {
      const searchUrl = `https://en.wikipedia.org/w/api.php?action=opensearch&search=${encodeURIComponent(query)}&limit=5&namespace=0&format=json&origin=*`;
      const sres = await fetch(searchUrl);
      if (!sres.ok) return null;
      const data = await sres.json();
      const titles = data[1] || [];
      for (const title of titles) {
        try {
          const summaryUrl = `https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(title.replace(/ /g, '_'))}`;
          const res = await fetch(summaryUrl);
          if (!res.ok) continue;
          const summary = await res.json();
          if (summary.type === 'disambiguation') continue;
          if (!summary.extract || summary.extract.length < 50) continue;
          return {
            title: summary.title,
            extract: summary.extract,
            url: summary.content_urls?.desktop?.page || ''
          };
        } catch {}
      }
      return null;
    } catch (err) {
      return null;
    }
  }

  async function buildWikiContext(userQuery) {
    const queries = generateWikiQueries(userQuery);
    const articles = [];
    const seenTitles = new Set();
    for (const q of queries) {
      if (articles.length >= 2) break;
      const article = await fetchWikipediaArticle(q);
      if (article && !seenTitles.has(article.title)) {
        seenTitles.add(article.title);
        articles.push(article);
      }
    }
    if (!articles.length) return '';
    return articles.map(a => {
      const extract = a.extract.slice(0, 2000);
      return `WIKIPEDIA — "${a.title}":\n${extract}${a.extract.length > 2000 ? '…' : ''}\nSource: ${a.url}`;
    }).join('\n\n');
  }

  function buildNewsContext(userQuery) {
    if (!wsjHeadlines.length) return '';
    const items = findRelevantHeadlines(userQuery, 6);
    if (!items.length) return '';
    const lines = items.map((h, i) => {
      const date = h.pubDate ? new Date(h.pubDate).toLocaleString('en-US', { month: 'short', day: 'numeric' }) : '';
      const summary = h.summary ? ` — ${h.summary.slice(0, 140)}${h.summary.length > 140 ? '…' : ''}` : '';
      return `${i+1}. [${h.publisher}] ${h.title}${date ? ' (' + date + ')' : ''}${summary} ${h.link}`;
    }).join('\n');
    return [
      `RECENT HEADLINES (WSJ, FT, BBC, CNN — live RSS):`,
      lines,
      `Cite the publisher named in [brackets]. Only the headline and short summary are available, no full article body. If the headlines don't cover the topic, say so.`
    ].join('\n');
  }

  function setProgress(p) {
    if (p == null) {
      progressBar.classList.remove('active');
      return;
    }
    progressBar.classList.add('active');
    progressFill.style.width = `${Math.round(p * 100)}%`;
  }

  function enableUI() {
    input.disabled = false;
    sendBtn.disabled = false;
    resetBtn.disabled = false;
    modelSelect.disabled = false;
    input.placeholder = 'Message AI…';
    input.focus();
  }

  function disableUI() {
    input.disabled = true;
    sendBtn.disabled = true;
    resetBtn.disabled = true;
    modelSelect.disabled = true;
  }

  function checkWebGPU() {
    if (!('gpu' in navigator)) {
      appendMessage('system',
        'WebGPU is not available in this browser. In-browser AI needs WebGPU — try the latest Chrome, Edge, or Brave on desktop, or enable it in your browser flags.',
        { error: true });
      setStatus('WebGPU unavailable');
      return false;
    }
    return true;
  }

  async function loadModel(modelId) {
    disableUI();
    setStatus('downloading model…');
    setProgress(0);

    try {
      engine = await webllm.CreateMLCEngine(modelId, {
        initProgressCallback: (report) => {
          setStatus(report.text || 'loading…');
          if (typeof report.progress === 'number') {
            setProgress(report.progress);
          }
        }
      });
      setProgress(null);
      setStatus(`ready · ${shortName(modelId)}`);
      enableUI();
    } catch (err) {
      console.error(err);
      setProgress(null);
      setStatus('failed to load');
      appendMessage('system',
        `Couldn't load the model: ${err.message || err}. Try a smaller model from the dropdown, or check that your browser supports WebGPU.`,
        { error: true });
      modelSelect.disabled = false;
    }
  }

  function shortName(id) {
    return id.replace(/-q4f16_1-MLC$/, '').replace(/-Instruct$/, '');
  }

  async function sendMessage() {
    if (isGenerating || !engine) return;
    const message = input.value.trim();
    if (!message) return;

    input.value = '';
    input.style.height = 'auto';
    isGenerating = true;
    sendBtn.disabled = true;
    input.disabled = true;
    resetBtn.disabled = true;

    appendMessage('user', message);
    history[0] = { role: 'system', content: buildSystemPrompt() };
    history.push({ role: 'user', content: message });
    showTyping();

    const newsBlock = buildNewsContext(message);
    const wikiBlock = await buildWikiContext(message);
    const extras = [wikiBlock, newsBlock].filter(Boolean).join('\n\n---\n\n');
    const messagesToSend = extras
      ? [
          { role: 'system', content: history[0].content + '\n\n---\n\n' + extras },
          ...history.slice(1)
        ]
      : history;

    try {
      const stream = await engine.chat.completions.create({
        messages: messagesToSend,
        stream: true,
        temperature: 0.7,
        max_tokens: 512
      });

      let bubble = null;
      let full = '';

      for await (const chunk of stream) {
        const delta = chunk.choices[0]?.delta?.content || '';
        if (!delta) continue;
        if (!bubble) {
          removeTyping();
          bubble = appendMessage('assistant', '');
        }
        full += delta;
        bubble.textContent = full;
        chatWindow.scrollTop = chatWindow.scrollHeight;
      }

      if (!bubble) {
        removeTyping();
        bubble = appendMessage('assistant', '(empty response)');
      }
      history.push({ role: 'assistant', content: full });
    } catch (err) {
      console.error(err);
      removeTyping();
      appendMessage('assistant', `Error: ${err.message || err}`, { error: true });
    }

    isGenerating = false;
    sendBtn.disabled = false;
    input.disabled = false;
    resetBtn.disabled = false;
    input.focus();
  }

  function resetChat() {
    if (isGenerating) return;
    history = [{ role: 'system', content: buildSystemPrompt() }];
    chatWindow.innerHTML = `
      <div class="welcome" id="welcome-msg">
        <h2>Fresh chat</h2>
        <p>Conversation cleared. Ask me anything.</p>
      </div>
    `;
    loadNews();
    input.focus();
  }

  input.addEventListener('input', () => {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 150) + 'px';
  });

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  sendBtn.addEventListener('click', sendMessage);
  resetBtn.addEventListener('click', resetChat);

  modelSelect.addEventListener('change', async () => {
    if (isGenerating) return;
    history = [{ role: 'system', content: buildSystemPrompt() }];
    chatWindow.innerHTML = `
      <div class="welcome" id="welcome-msg">
        <h2>Switching model…</h2>
        <p>Loading ${shortName(modelSelect.value)}. First time may take a minute.</p>
      </div>
    `;
    await loadModel(modelSelect.value);
  });

  if (checkWebGPU()) {
    loadModel(modelSelect.value);
    loadNews();
  }
</script>
</body>
</html>
