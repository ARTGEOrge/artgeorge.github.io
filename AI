<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>In-Browser AI Chat</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: #0b0f1a;
      color: #e5e7eb;
      height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    #app {
      width: 100%;
      max-width: 860px;
      height: 100vh;
      display: flex;
      flex-direction: column;
      background: #111827;
      box-shadow: 0 0 40px rgba(0,0,0,0.6);
    }

    header {
      padding: 14px 22px;
      background: #0f172a;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      border-bottom: 1px solid #1f2937;
      flex-wrap: wrap;
    }

    header h1 {
      font-size: 1.15rem;
      font-weight: 700;
      background: linear-gradient(135deg, #818cf8 0%, #c084fc 60%, #f472b6 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .meta {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.8rem;
      color: #94a3b8;
    }

    #model-select {
      background: #0b1220;
      color: #e5e7eb;
      border: 1px solid #1f2937;
      border-radius: 8px;
      padding: 6px 10px;
      font-size: 0.8rem;
      cursor: pointer;
      outline: none;
      max-width: 220px;
    }

    #model-select:focus { border-color: #818cf8; }

    #reset-btn {
      background: transparent;
      border: 1px solid #818cf8;
      color: #c7d2fe;
      padding: 6px 14px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.8rem;
      transition: all 0.2s;
    }

    #reset-btn:hover { background: #818cf8; color: #0b0f1a; }
    #reset-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    #progress-bar {
      width: 100%;
      height: 3px;
      background: #1f2937;
      overflow: hidden;
      display: none;
    }

    #progress-bar.active { display: block; }

    #progress-fill {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, #818cf8, #c084fc, #f472b6);
      transition: width 0.3s ease;
    }

    #chat-window {
      flex: 1;
      overflow-y: auto;
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      scroll-behavior: smooth;
    }

    #chat-window::-webkit-scrollbar { width: 6px; }
    #chat-window::-webkit-scrollbar-track { background: transparent; }
    #chat-window::-webkit-scrollbar-thumb { background: #1f2937; border-radius: 3px; }

    .message {
      display: flex;
      gap: 12px;
      max-width: 88%;
      animation: fadeIn 0.25s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .message.user { align-self: flex-end; flex-direction: row-reverse; }
    .message.assistant { align-self: flex-start; }
    .message.system { align-self: center; max-width: 95%; }

    .avatar {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      flex-shrink: 0;
    }

    .message.user .avatar { background: linear-gradient(135deg, #f472b6, #c084fc); }
    .message.assistant .avatar { background: linear-gradient(135deg, #818cf8, #6366f1); }

    .bubble {
      padding: 11px 15px;
      border-radius: 16px;
      line-height: 1.55;
      font-size: 0.95rem;
      white-space: pre-wrap;
      word-break: break-word;
    }

    .message.user .bubble {
      background: linear-gradient(135deg, #6d28d9, #be185d);
      color: white;
      border-bottom-right-radius: 4px;
    }

    .message.assistant .bubble {
      background: #1e293b;
      color: #e5e7eb;
      border: 1px solid #334155;
      border-bottom-left-radius: 4px;
    }

    .bubble.error {
      background: #450a0a;
      border-color: #7f1d1d;
      color: #fecaca;
    }

    .bubble.info {
      background: #1e1b4b;
      border-color: #3730a3;
      color: #c7d2fe;
      font-size: 0.85rem;
    }

    .typing-indicator span {
      display: inline-block;
      width: 7px; height: 7px;
      background: #94a3b8;
      border-radius: 50%;
      margin: 0 2px;
      animation: bounce 1.2s infinite;
    }

    .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

    @keyframes bounce {
      0%, 80%, 100% { transform: translateY(0); }
      40% { transform: translateY(-7px); }
    }

    #input-area {
      padding: 14px 22px;
      background: #0f172a;
      display: flex;
      gap: 10px;
      align-items: flex-end;
      border-top: 1px solid #1f2937;
    }

    #user-input {
      flex: 1;
      background: #0b1220;
      border: 1px solid #1f2937;
      border-radius: 12px;
      padding: 12px 16px;
      color: #e5e7eb;
      font-size: 0.95rem;
      resize: none;
      max-height: 150px;
      outline: none;
      transition: border-color 0.2s;
      font-family: inherit;
    }

    #user-input:focus { border-color: #818cf8; }
    #user-input::placeholder { color: #475569; }
    #user-input:disabled { opacity: 0.5; }

    #send-btn {
      background: linear-gradient(135deg, #818cf8, #c084fc);
      border: none;
      border-radius: 12px;
      width: 48px;
      height: 48px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: filter 0.2s, transform 0.1s;
      flex-shrink: 0;
    }

    #send-btn:hover { filter: brightness(1.1); }
    #send-btn:active { transform: scale(0.95); }
    #send-btn:disabled { background: #334155; cursor: not-allowed; filter: none; }
    #send-btn svg { width: 20px; height: 20px; fill: white; }

    .welcome {
      text-align: center;
      color: #64748b;
      margin: auto;
      padding: 0 24px;
    }

    .welcome h2 {
      font-size: 1.5rem;
      margin-bottom: 10px;
      background: linear-gradient(135deg, #818cf8, #f472b6);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .welcome p { font-size: 0.92rem; line-height: 1.6; }
    .welcome .hint { margin-top: 10px; font-size: 0.8rem; color: #475569; }
  </style>
</head>
<body>
<div id="app">
  <header>
    <h1>In-Browser AI</h1>
    <div class="meta">
      <select id="model-select" title="Choose model">
        <option value="Llama-3.2-3B-Instruct-q4f16_1-MLC">Llama 3.2 3B (balanced)</option>
        <option value="Llama-3.2-1B-Instruct-q4f16_1-MLC">Llama 3.2 1B (fast)</option>
        <option value="Phi-3.5-mini-instruct-q4f16_1-MLC">Phi 3.5 Mini</option>
        <option value="Qwen2.5-3B-Instruct-q4f16_1-MLC">Qwen 2.5 3B</option>
        <option value="gemma-2-2b-it-q4f16_1-MLC">Gemma 2 2B</option>
        <option value="Hermes-3-Llama-3.2-3B-q4f16_1-MLC">Hermes 3 (Llama 3.2 3B)</option>
      </select>
      <span id="status-label">initializing…</span>
    </div>
    <button id="reset-btn" disabled>New Chat</button>
  </header>

  <div id="progress-bar"><div id="progress-fill"></div></div>

  <div id="chat-window">
    <div class="welcome" id="welcome-msg">
      <h2>Modern AI, running in your browser</h2>
      <p>This page loads an open-source LLM directly into your browser using WebGPU — no server, no API key, your messages never leave your device.</p>
      <p class="hint">The first message will trigger a one-time model download (a few hundred MB). It's cached after that.</p>
    </div>
  </div>

  <div id="input-area">
    <textarea
      id="user-input"
      rows="1"
      placeholder="Loading model… one moment"
      disabled
    ></textarea>
    <button id="send-btn" disabled title="Send">
      <svg viewBox="0 0 24 24"><path d="M2 21l21-9L2 3v7l15 2-15 2z"/></svg>
    </button>
  </div>
</div>

<script type="module">
  import * as webllm from "https://esm.run/@mlc-ai/web-llm@0.2.79";

  const chatWindow = document.getElementById('chat-window');
  const input = document.getElementById('user-input');
  const sendBtn = document.getElementById('send-btn');
  const resetBtn = document.getElementById('reset-btn');
  const modelSelect = document.getElementById('model-select');
  const statusLabel = document.getElementById('status-label');
  const progressBar = document.getElementById('progress-bar');
  const progressFill = document.getElementById('progress-fill');

  let engine = null;
  let isGenerating = false;

  function buildSystemPrompt() {
    const now = new Date();
    const iso = now.toISOString().slice(0, 16).replace('T', ' ');
    const dateStr = now.toLocaleDateString('en-US', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
    });
    const timeStr = now.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
    const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
    const year = now.getFullYear();
    const lang = navigator.language || 'en-US';

    return [
      `IMPORTANT — TODAY'S DATE IS ${dateStr}. THE YEAR IS ${year}. THE CURRENT LOCAL TIME IS ${timeStr} (${tz}). ISO: ${iso}.`,
      `If the user asks the date, time, year, or day of the week, answer using ONLY the values above. Do not say it is any other year. Your training data is older than this date.`,
      '',
      'You are an in-browser AI assistant running entirely inside the user\'s web browser using WebLLM and WebGPU. There is no cloud server; messages never leave the device.',
      '',
      `You are hosted on artgeorge.github.io, a personal site with browser games and this chat page. The user's browser language is ${lang}.`,
      '',
      'Your training data has a knowledge cutoff and you may not know about events after it. When asked about recent events, say what you do and don\'t know rather than guessing.',
      '',
      'Style: friendly, accurate, and direct. Match the user\'s language. Use Markdown when helpful. Keep code blocks short and runnable. If you\'re unsure, say so.',
      '',
      `Reminder: today is ${dateStr}, year ${year}.`
    ].join('\n');
  }

  let history = [
    { role: 'system', content: buildSystemPrompt() }
  ];

  function escapeHtml(text) {
    return text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function clearWelcome() {
    const w = document.getElementById('welcome-msg');
    if (w) w.remove();
  }

  function appendMessage(role, content, opts = {}) {
    clearWelcome();
    const div = document.createElement('div');
    div.className = `message ${role}`;
    const avatar = role === 'user' ? '🧑' : (role === 'system' ? 'ℹ️' : '✨');
    const bubbleClass = opts.error ? 'error' : (role === 'system' ? 'info' : '');
    div.innerHTML = `
      <div class="avatar">${avatar}</div>
      <div class="bubble ${bubbleClass}">${escapeHtml(content)}</div>
    `;
    chatWindow.appendChild(div);
    chatWindow.scrollTop = chatWindow.scrollHeight;
    return div.querySelector('.bubble');
  }

  function showTyping() {
    clearWelcome();
    const div = document.createElement('div');
    div.className = 'message assistant';
    div.id = 'typing';
    div.innerHTML = `
      <div class="avatar">✨</div>
      <div class="bubble typing-indicator">
        <span></span><span></span><span></span>
      </div>
    `;
    chatWindow.appendChild(div);
    chatWindow.scrollTop = chatWindow.scrollHeight;
  }

  function removeTyping() {
    const t = document.getElementById('typing');
    if (t) t.remove();
  }

  function setStatus(text) {
    statusLabel.textContent = text;
  }

  function setProgress(p) {
    if (p == null) {
      progressBar.classList.remove('active');
      return;
    }
    progressBar.classList.add('active');
    progressFill.style.width = `${Math.round(p * 100)}%`;
  }

  function enableUI() {
    input.disabled = false;
    sendBtn.disabled = false;
    resetBtn.disabled = false;
    modelSelect.disabled = false;
    input.placeholder = 'Message AI…';
    input.focus();
  }

  function disableUI() {
    input.disabled = true;
    sendBtn.disabled = true;
    resetBtn.disabled = true;
    modelSelect.disabled = true;
  }

  function checkWebGPU() {
    if (!('gpu' in navigator)) {
      appendMessage('system',
        'WebGPU is not available in this browser. In-browser AI needs WebGPU — try the latest Chrome, Edge, or Brave on desktop, or enable it in your browser flags.',
        { error: true });
      setStatus('WebGPU unavailable');
      return false;
    }
    return true;
  }

  async function loadModel(modelId) {
    disableUI();
    setStatus('downloading model…');
    setProgress(0);

    try {
      engine = await webllm.CreateMLCEngine(modelId, {
        initProgressCallback: (report) => {
          setStatus(report.text || 'loading…');
          if (typeof report.progress === 'number') {
            setProgress(report.progress);
          }
        }
      });
      setProgress(null);
      setStatus(`ready · ${shortName(modelId)}`);
      enableUI();
    } catch (err) {
      console.error(err);
      setProgress(null);
      setStatus('failed to load');
      appendMessage('system',
        `Couldn't load the model: ${err.message || err}. Try a smaller model from the dropdown, or check that your browser supports WebGPU.`,
        { error: true });
      modelSelect.disabled = false;
    }
  }

  function shortName(id) {
    return id.replace(/-q4f16_1-MLC$/, '').replace(/-Instruct$/, '');
  }

  async function sendMessage() {
    if (isGenerating || !engine) return;
    const message = input.value.trim();
    if (!message) return;

    input.value = '';
    input.style.height = 'auto';
    isGenerating = true;
    sendBtn.disabled = true;
    input.disabled = true;
    resetBtn.disabled = true;

    appendMessage('user', message);
    history[0] = { role: 'system', content: buildSystemPrompt() };
    history.push({ role: 'user', content: message });
    showTyping();

    try {
      const stream = await engine.chat.completions.create({
        messages: history,
        stream: true,
        temperature: 0.7,
        max_tokens: 1024
      });

      let bubble = null;
      let full = '';

      for await (const chunk of stream) {
        const delta = chunk.choices[0]?.delta?.content || '';
        if (!delta) continue;
        if (!bubble) {
          removeTyping();
          bubble = appendMessage('assistant', '');
        }
        full += delta;
        bubble.textContent = full;
        chatWindow.scrollTop = chatWindow.scrollHeight;
      }

      if (!bubble) {
        removeTyping();
        bubble = appendMessage('assistant', '(empty response)');
      }
      history.push({ role: 'assistant', content: full });
    } catch (err) {
      console.error(err);
      removeTyping();
      appendMessage('assistant', `Error: ${err.message || err}`, { error: true });
    }

    isGenerating = false;
    sendBtn.disabled = false;
    input.disabled = false;
    resetBtn.disabled = false;
    input.focus();
  }

  function resetChat() {
    if (isGenerating) return;
    history = [{ role: 'system', content: buildSystemPrompt() }];
    chatWindow.innerHTML = `
      <div class="welcome" id="welcome-msg">
        <h2>Fresh chat</h2>
        <p>Conversation cleared. Ask me anything.</p>
      </div>
    `;
    input.focus();
  }

  input.addEventListener('input', () => {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 150) + 'px';
  });

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  sendBtn.addEventListener('click', sendMessage);
  resetBtn.addEventListener('click', resetChat);

  modelSelect.addEventListener('change', async () => {
    if (isGenerating) return;
    history = [{ role: 'system', content: buildSystemPrompt() }];
    chatWindow.innerHTML = `
      <div class="welcome" id="welcome-msg">
        <h2>Switching model…</h2>
        <p>Loading ${shortName(modelSelect.value)}. First time may take a minute.</p>
      </div>
    `;
    await loadModel(modelSelect.value);
  });

  if (checkWebGPU()) {
    loadModel(modelSelect.value);
  }
</script>
</body>
</html>
