<!DOCTYPE html>
<html>
<head>
  <title>Tennis Game</title>
  <style>
    body {
      margin: 0;
      overflow: hidden;
      background: black;
    }

    canvas {
      display: block;
      margin: auto;
      background: #0b6623;
    }
  </style>
</head>
<body>

<canvas id="gameCanvas" width="800" height="500"></canvas>

<script>
const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");

const paddleWidth = 10;
const paddleHeight = 100;

let playerY = 200;
let aiY = 200;

let ballX = 400;
let ballY = 250;

let ballSpeedX = 5;
let ballSpeedY = 4;

document.addEventListener("mousemove", (e) => {
  const rect = canvas.getBoundingClientRect();
  playerY = e.clientY - rect.top - paddleHeight / 2;
});

function drawRect(x, y, w, h, color) {
  ctx.fillStyle = color;
  ctx.fillRect(x, y, w, h);
}

function drawBall(x, y, r, color) {
  ctx.fillStyle = color;
  ctx.beginPath();
  ctx.arc(x, y, r, 0, Math.PI * 2);
  ctx.fill();
}

function update() {
  ballX += ballSpeedX;
  ballY += ballSpeedY;

  // Top/bottom bounce
  if (ballY < 0 || ballY > canvas.height) {
    ballSpeedY *= -1;
  }

  // AI movement
  aiY += ((ballY - (aiY + paddleHeight / 2))) * 0.08;

  // Left paddle collision
  if (
    ballX < 20 &&
    ballY > playerY &&
    ballY < playerY + paddleHeight
  ) {
    ballSpeedX *= -1;
  }

  // Right paddle collision
  if (
    ballX > 770 &&
    ballY > aiY &&
    ballY < aiY + paddleHeight
  ) {
    ballSpeedX *= -1;
  }

  // Reset ball
  if (ballX < 0 || ballX > canvas.width) {
    ballX = 400;
    ballY = 250;
  }
}

function draw() {
  drawRect(0, 0, canvas.width, canvas.height, "#0b6623");

  // Net
  for (let i = 0; i < canvas.height; i += 30) {
    drawRect(398, i, 4, 20, "white");
  }

  // Paddles
  drawRect(10, playerY, paddleWidth, paddleHeight, "white");
  drawRect(780, aiY, paddleWidth, paddleHeight, "white");

  // Ball
  drawBall(ballX, ballY, 10, "yellow");
}

function gameLoop() {
  update();
  draw();
  requestAnimationFrame(gameLoop);
}

gameLoop();
</script>

</body>
</html>
